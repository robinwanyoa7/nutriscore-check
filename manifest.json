{
  "manifest_version": 3,
  "name": "NutriScore Tool",
  "version": "0.1",
  "description": "Real-time nutritional tracking analysis for grocery websites",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.naivas.online/*",
    "*://*.naivas.co.ke/*",
    "file:///*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "NutriScore"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.naivas.online/*",
        "*://*.naivas.co.ke/*",
        "file:///*"
      ],
      "js": [
        "src/scraper.js",
        "src/iconLayer.js",
        "src/nutrientBar.js",
        "src/overlayLayer.js",
        "src/tooltip.js",
        "src/onlineStoreRunner.js",
        "src/activatePrompt.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}